<% layout("layouts/boilerplate.ejs") %>
<div class="row">
  <div class="col-10 offset-1">
    <h3 class="mb-3">Edit listing</h3>
    <form
      action="/listings/<%= listing._id %>?_method=PUT"
      method="POST"
      class="mt-3"
    >
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          type="text"
          id="title"
          class="form-control"
          name="listing[title]"
          value="<%= listing.title %>"
        />
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          name="listing[description]"
          id="description"
          class="form-control"
        >
<%= listing.description %></textarea
        >
      </div>

      <div class="mb-3">
        <label for="img-url" class="form-label">Image link</label>
        <input
          type="text"
          id="img-url"
          name="listing[image]"
          class="form-control"
          value="<%= listing.image %>"
        />
      </div>

      <div class="row">
        <div class="mb-3 col-12 col-md-5">
          <label for="price" class="form-label">Price</label>
          <div class="input-group">
            <span class="input-group-text">₹</span>
            <input
              type="number"
              id="price"
              class="form-control"
              name="listing[price]"
              value="<%= listing.price %>"
            />
          </div>
        </div>

        <div class="mb-3 col-12 col-md-7">
          <label for="country" class="form-label">country</label>
          <input
            type="text"
            id="country"
            class="form-control"
            name="listing[country]"
            value="<%= listing.country %>"
          />
        </div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input
          type="text"
          id="location"
          class="form-control"
          name="listing[location]"
          value="<%= listing.location %>"
        />
      </div>

      <button class="btn add-btn mb-3 mt-1">Add</button>
    </form>
  </div>
</div>
